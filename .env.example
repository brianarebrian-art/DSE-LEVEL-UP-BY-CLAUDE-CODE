# ─────────────────────────────────────────────────────────────
# Google login (Auth.js / NextAuth v5)
# Copy this file to `.env.local`, fill in the values, then restart the dev server.
# The whole site runs WITHOUT these — only the actual Google sign-in needs them.
# ─────────────────────────────────────────────────────────────

# Show the login UI. The Free/Premium plan is read from the signed-in session.
NEXT_PUBLIC_AUTH_ENABLED=true

# Google Cloud Console → APIs & Services → Credentials → Create OAuth client ID
# → "Web application". Add BOTH authorised redirect URIs (local dev + production):
#   http://localhost:3001/api/auth/callback/google
#   https://YOUR-DOMAIN/api/auth/callback/google
# The client ID is public; keep the client SECRET private (never commit it).
AUTH_GOOGLE_ID=your-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-client-secret

# Session-signing secret. Generate one with:  openssl rand -base64 33
AUTH_SECRET=replace-with-a-long-random-string

# trustHost is enabled in auth.ts, so AUTH_URL is NOT required on Vercel —
# just make sure the production redirect URI above is added in Google Console.

# Premium testers (comma-separated emails). Sign-in is open to all; these emails get
# Premium for free (your team). @lhymss.net school emails always get Premium too.
ALLOWED_EMAILS=you@example.com

# Manually-granted Premium (Plan A, offline payment). Comma-separated emails of
# users who paid you. Adding an email lets them sign in AND unlocks Premium.
PREMIUM_EMAILS=
