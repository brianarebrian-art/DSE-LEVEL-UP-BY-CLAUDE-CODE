# ─────────────────────────────────────────────────────────────
# Google login (Auth.js / NextAuth v5)
# Copy this file to `.env.local` and fill in the values.
# The site works WITHOUT these — login just stays hidden until configured.
# ─────────────────────────────────────────────────────────────

# Turn the login UI on (set to "true" only after the 3 values below are filled):
NEXT_PUBLIC_AUTH_ENABLED=true

# From Google Cloud Console → APIs & Services → Credentials →
# Create OAuth client ID → "Web application".
# Authorized redirect URI (local):  http://localhost:3001/api/auth/callback/google
# Authorized redirect URI (prod):   https://YOUR-DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=your-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-client-secret

# A random secret for signing sessions. Generate one with:
#   openssl rand -base64 33
AUTH_SECRET=replace-with-a-long-random-string
